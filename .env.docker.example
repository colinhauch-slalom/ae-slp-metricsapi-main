# Environment variables for Docker Compose
# Copy this file to .env.docker and adjust values as needed.

# Server
METRICS_SERVER_PORT=3000
METRICS_SERVER_HOST=0.0.0.0

# PostgreSQL
METRICS_DB_HOST=postgres
METRICS_DB_PORT=5432
METRICS_DB_NAME=metricsapi
METRICS_DB_PASSWORD=alex_local_dev
METRICS_DB_USER=postgres

# Redis
# [DEF-001] INTENTIONAL ISSUE: The Redis port below is WRONG.
# The correct default Redis port is 6379. This uses 6380, which will cause
# connection failures until the developer fixes it.
METRICS_REDIS_HOST=redis
METRICS_REDIS_PORT=6380
